{
  "swagger": "2.0",
  "info": {
    "title": "HFUT 合肥工业大学 - 学校对接 API",
    "description": "合肥工业大学对接的学校端登录、绑定学校接口说明。主 API 见 doc/openapi.json",
    "version": "1.0.0"
  },
  "basePath": "/",
  "schemes": ["https", "http"],
  "tags": [
    {"name": "HFUT", "description": "合肥工业大学对接"}
  ],
  "paths": {
    "/api/v1/schools": {
      "get": {
        "tags": ["HFUT"],
        "summary": "学校列表（绑定表单用）",
        "description": "需 JWT。返回 id、name、code、form_fields、captcha_url。form_fields 含 captcha 时需先调 captcha 接口。",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {"description": "list 每项含 form_fields: [{key,label_zh,label_en}]"}
        }
      }
    },
    "/api/v1/schools/:id/captcha": {
      "get": {
        "tags": ["HFUT"],
        "summary": "获取验证码",
        "description": "需 JWT。返回 base64 图片及 token，token 用于 bind/school 或 school-login。",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "path", "name": "id", "type": "integer", "required": true}],
        "responses": {
          "200": {"description": "data: { image, token }"}
        }
      }
    },
    "/api/v1/user/school-login": {
      "post": {
        "tags": ["HFUT"],
        "summary": "学校端登录（HFUT）",
        "description": "school_code 固定为 `hfut`。对接 CAS，验证码由后端 OCR 自动处理。",
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {
            "type": "object",
            "required": ["school_code", "username", "password"],
            "properties": {
              "school_code": {"type": "string", "example": "hfut", "description": "固定为 hfut"},
              "username": {"type": "string", "example": "2021234567", "description": "学号"},
              "password": {"type": "string", "description": "学校统一认证密码"}
            }
          }
        }],
        "responses": {
          "200": {
            "description": "验证成功",
            "schema": {
              "type": "object",
              "properties": {
                "code": {"type": "integer", "example": 200},
                "message": {"type": "string"},
                "data": {
                  "type": "object",
                  "properties": {
                    "student_id": {"type": "string", "description": "学号"},
                    "name": {"type": "string", "description": "姓名（如有）"}
                  }
                }
              }
            }
          },
          "400": {"description": "账号密码错误或验证码识别失败"}
        }
      }
    },
    "/api/v1/user/bind/school": {
      "post": {
        "tags": ["HFUT"],
        "summary": "绑定学校（HFUT）",
        "description": "需 JWT。HFUT 需验证码：先 GET /schools/:id/captcha 获取 image、token，填写后传入 captcha、captcha_token。",
        "security": [{"BearerAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {
            "type": "object",
            "required": ["school_id", "username", "password", "captcha", "captcha_token"],
            "properties": {
              "school_id": {"type": "integer", "description": "合肥工业大学在 schools 表中的 ID"},
              "username": {"type": "string", "example": "2021234567", "description": "学号"},
              "password": {"type": "string", "description": "学校统一认证密码"},
              "captcha": {"type": "string", "description": "验证码（HFUT 必填）"},
              "captcha_token": {"type": "string", "description": "GET /schools/:id/captcha 返回的 token"}
            }
          }
        }],
        "responses": {
          "200": {"description": "绑定成功"},
          "400": {"description": "学校不存在/验证失败/该学校暂不支持在线认证"},
          "401": {"description": "未认证"}
        }
      }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT，格式：Bearer {token}"
    }
  }
}
