{
  "swagger": "2.0",
  "info": {
    "title": "HFUT Graduation Project API",
    "description": "合肥工业大学毕业设计项目 API。需 JWT 认证、学校隔离。\n\n**通用说明：**\n- 成功响应 code 均为 200\n- 认证方式：Header 添加 `Authorization: Bearer <token>`\n- extType: 1=帖子 2=提问 3=回答 4=商品",
    "version": "1.0.0"
  },
  "basePath": "/",
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT，格式：Bearer {token}，登录后从 data.token 获取"
    }
  },
  "tags": [
    {"name": "系统", "description": "健康检查"},
    {"name": "用户", "description": "注册、登录、个人信息"},
    {"name": "帖子", "description": "type=1 普通文章"},
    {"name": "提问", "description": "type=2 问答"},
    {"name": "回答", "description": "type=3 回答，创建需 parent_id"},
    {"name": "评论", "description": "评论与回复，path 传 extType"},
    {"name": "收藏", "description": "收藏夹与收藏"},
    {"name": "点赞", "description": "点赞与取消"},
    {"name": "OSS", "description": "文件存取"},
    {"name": "管理员", "description": "需 role>=2 管理员权限"}
  ],
  "definitions": {
    "Response": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {"type": "integer", "description": "200=成功，400=参数错误，401=未认证，403=无权限，404=不存在，500=服务器错误", "example": 200},
        "message": {"type": "string", "description": "提示信息", "example": "成功"},
        "data": {"description": "业务数据，成功时存在"}
      }
    },
    "ResponseSuccess": {
      "allOf": [
        {"$ref": "#/definitions/Response"},
        {"properties": {"code": {"example": 200}, "message": {"example": "成功"}}}
      ]
    },
    "ResponseError": {
      "allOf": [
        {"$ref": "#/definitions/Response"},
        {"properties": {"code": {"example": 400}, "message": {"example": "参数错误"}}}
      ]
    },
    "ArticleCreate": {
      "type": "object",
      "required": ["title", "content"],
      "properties": {
        "title": {"type": "string", "description": "标题", "example": "我的第一篇文章"},
        "content": {"type": "string", "description": "正文内容", "example": "这是文章正文..."},
        "publish_status": {"type": "integer", "description": "1=私密 2=公开", "default": 1},
        "parent_id": {"type": "integer", "description": "回答必传，对应提问ID"}
      },
      "example": {"title": "如何学习Go", "content": "Go语言学习心得...", "publish_status": 2}
    },
    "ArticleUpdate": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "content": {"type": "string"},
        "publish_status": {"type": "integer", "description": "1私密 2公开"}
      }
    },
    "ArticleImages": {
      "type": "object",
      "required": ["images"],
      "properties": {
        "images": {"type": "array", "items": {"type": "string"}, "description": "图片URL数组"}
      },
      "example": {"images": ["/oss/user/1/img1.jpg", "/oss/user/1/img2.jpg"]}
    },
    "Article": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "user_id": {"type": "integer"},
        "school_id": {"type": "integer"},
        "parent_id": {"type": "integer"},
        "title": {"type": "string"},
        "content": {"type": "string"},
        "status": {"type": "integer", "description": "1正常 2禁用"},
        "publish_status": {"type": "integer"},
        "type": {"type": "integer", "description": "1帖子 2提问 3回答"},
        "view_count": {"type": "integer"},
        "like_count": {"type": "integer"},
        "collect_count": {"type": "integer"},
        "images": {"type": "array", "items": {"type": "string"}},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "ArticleListResponse": {
      "properties": {
        "list": {"type": "array", "items": {"$ref": "#/definitions/Article"}},
        "total": {"type": "integer"},
        "page": {"type": "integer"},
        "page_size": {"type": "integer"}
      },
      "example": {"list": [{"id": 1, "title": "标题", "content": "内容", "status": 1, "type": 1}], "total": 100, "page": 1, "page_size": 20}
    },
    "CommentCreate": {
      "type": "object",
      "required": ["content"],
      "properties": {
        "content": {"type": "string", "example": "评论内容"},
        "parent_id": {"type": "integer", "description": "回复时传父评论ID"},
        "reply_id": {"type": "integer", "description": "回复某条回复时传被回复者ID"}
      },
      "example": {"content": "说得对！"}
    },
    "LoginToken": {
      "type": "object",
      "properties": {"token": {"type": "string", "description": "JWT，后续请求放在 Authorization: Bearer {token}"}}
    },
    "UserInfo": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "username": {"type": "string"},
        "avatar": {"type": "string"},
        "background": {"type": "string"},
        "follow_count": {"type": "integer"},
        "fans_count": {"type": "integer"},
        "role": {"type": "integer", "description": "1普通 2管理员 3超管 4匿名"},
        "status": {"type": "integer", "description": "1正常 2禁用"},
        "school_id": {"type": "integer"}
      }
    },
    "UserAdmin": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "username": {"type": "string"},
        "school_id": {"type": "integer"},
        "status": {"type": "integer", "description": "1正常 2禁用"},
        "role": {"type": "integer", "description": "1普通 2管理员 3超管 4匿名"},
        "follow_count": {"type": "integer"},
        "fans_count": {"type": "integer"},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "School": {
      "type": "object",
      "properties": {
        "id": {"type": "integer"},
        "name": {"type": "string"},
        "login_url": {"type": "string"},
        "user_count": {"type": "integer"},
        "status": {"type": "integer", "description": "1正常 2禁用"},
        "created_at": {"type": "string"}
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["系统"],
        "summary": "健康检查",
        "responses": {
          "200": {
            "description": "服务正常",
            "schema": {"type": "object", "properties": {"status": {"type": "string", "example": "ok"}}}
          }
        }
      }
    },
    "/api/v1/admin/login": {
      "post": {
        "tags": ["管理员"],
        "summary": "管理员登录",
        "description": "仅 role>=2 的管理员可登录，返回 JWT 用于后续管理员接口",
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {
            "type": "object",
            "required": ["username", "password"],
            "properties": {
              "username": {"type": "string", "example": "admin"},
              "password": {"type": "string", "example": "your_password"}
            }
          }
        }],
        "responses": {
          "200": {
            "description": "登录成功",
            "schema": {
              "allOf": [
                {"$ref": "#/definitions/Response"},
                {"properties": {"data": {"$ref": "#/definitions/LoginToken"}}}
              ]
            },
            "examples": {"application/json": {"code": 200, "message": "登录成功", "data": {"token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."}}}
          },
          "400": {"description": "参数错误/用户不存在/密码错误", "schema": {"$ref": "#/definitions/Response"}, "examples": {"application/json": {"code": 500, "message": "密码错误"}}},
          "500": {"description": "无管理员权限/账户已禁用", "schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/register": {
      "post": {
        "tags": ["用户"],
        "summary": "注册",
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {
            "type": "object",
            "required": ["username", "password", "re_password"],
            "properties": {
              "username": {"type": "string", "example": "zhangsan"},
              "password": {"type": "string", "example": "password123"},
              "re_password": {"type": "string", "example": "password123"}
            }
          }
        }],
        "responses": {
          "200": {"description": "注册成功", "schema": {"$ref": "#/definitions/Response"}, "examples": {"application/json": {"code": 200, "message": "成功", "data": {"user_id": 1}}}},
          "400": {"description": "两次密码不一致/用户已存在", "schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/login": {
      "post": {
        "tags": ["用户"],
        "summary": "用户登录",
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {
            "type": "object",
            "required": ["username", "password"],
            "properties": {
              "username": {"type": "string", "example": "zhangsan"},
              "password": {"type": "string", "example": "password123"}
            }
          }
        }],
        "responses": {
          "200": {
            "description": "登录成功，data 为 token 字符串或 {token: string}",
            "schema": {"$ref": "#/definitions/Response"},
            "examples": {"application/json": {"code": 200, "message": "登录成功", "data": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."}}
          },
          "400": {"description": "用户不存在/密码错误", "schema": {"$ref": "#/definitions/Response"}},
          "500": {"description": "账户已被禁用", "schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/info": {
      "get": {
        "tags": ["用户"],
        "summary": "当前用户信息",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "用户信息",
            "schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/UserInfo"}}}]},
            "examples": {"application/json": {"code": 200, "message": "成功", "data": {"id": 1, "username": "zhangsan", "avatar": "", "background": "", "follow_count": 0, "fans_count": 0, "role": 1, "status": 1, "school_id": 1}}}
          },
          "401": {"description": "未认证/token无效", "schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/update": {
      "post": {
        "tags": ["用户"],
        "summary": "更新个人信息",
        "security": [{"BearerAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "schema": {
            "type": "object",
            "properties": {
              "avatar": {"type": "string"},
              "background": {"type": "string"},
              "bind_qq": {"type": "string"},
              "bind_wx": {"type": "string"},
              "bind_phone": {"type": "string"}
            }
          }
        }],
        "responses": {
          "200": {"schema": {"$ref": "#/definitions/Response"}},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/bind/school": {
      "post": {
        "tags": ["用户"],
        "summary": "绑定学校",
        "security": [{"BearerAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "required": true,
          "schema": {"type": "object", "required": ["school_id"], "properties": {"school_id": {"type": "integer", "description": "学校ID"}}}
        }],
        "responses": {
          "200": {"schema": {"$ref": "#/definitions/Response"}},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/avatar": {
      "post": {
        "tags": ["用户"],
        "summary": "上传头像",
        "security": [{"BearerAuth": []}],
        "consumes": ["multipart/form-data"],
        "parameters": [{"in": "formData", "name": "file", "type": "file", "required": true, "description": "图片文件"}],
        "responses": {
          "200": {"description": "data.url 为图片地址", "schema": {"$ref": "#/definitions/Response"}, "examples": {"application/json": {"code": 200, "message": "成功", "data": {"url": "/oss/user/1/avatar.jpg"}}}},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/user/background": {
      "post": {
        "tags": ["用户"],
        "summary": "上传背景",
        "security": [{"BearerAuth": []}],
        "consumes": ["multipart/form-data"],
        "parameters": [{"in": "formData", "name": "file", "type": "file", "required": true}],
        "responses": {
          "200": {"schema": {"$ref": "#/definitions/Response"}, "examples": {"application/json": {"code": 200, "message": "成功", "data": {"url": "/oss/user/1/bg.jpg"}}}},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/post": {
      "get": {
        "tags": ["帖子"],
        "summary": "帖子列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "page", "type": "integer", "default": 1},
          {"in": "query", "name": "pageSize", "type": "integer", "default": 20}
        ],
        "responses": {
          "200": {"description": "分页列表", "schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      },
      "post": {
        "tags": ["帖子"],
        "summary": "创建帖子",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleCreate"}}],
        "responses": {
          "200": {"schema": {"$ref": "#/definitions/Response"}, "examples": {"application/json": {"code": 200, "message": "成功", "data": {"id": 1}}}},
          "401": {"schema": {"$ref": "#/definitions/Response"}}
        }
      }
    },
    "/api/v1/post/search": {
      "get": {
        "tags": ["帖子"],
        "summary": "搜索帖子",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "q", "type": "string", "required": true, "description": "搜索关键词"},
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]}}, "401": {"schema": {"$ref": "#/definitions/Response"}}}
      }
    },
    "/api/v1/post/{id}": {
      "get": {
        "tags": ["帖子"],
        "summary": "帖子详情",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "path", "name": "id", "type": "integer", "required": true}],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/Article"}}}]}}, "401": {}, "404": {"schema": {"$ref": "#/definitions/Response"}}}
      },
      "put": {
        "tags": ["帖子"],
        "summary": "更新帖子",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleUpdate"}}
        ],
        "responses": {"200": {"schema": {"$ref": "#/definitions/Response"}}, "401": {}, "404": {"schema": {"$ref": "#/definitions/Response"}}}
      },
      "delete": {
        "tags": ["帖子"],
        "summary": "删除帖子（软删除）",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "path", "name": "id", "type": "integer", "required": true}],
        "responses": {"200": {"schema": {"$ref": "#/definitions/Response"}}, "401": {}, "404": {"schema": {"$ref": "#/definitions/Response"}}}
      }
    },
    "/api/v1/post/{id}/images": {
      "post": {
        "tags": ["帖子"],
        "summary": "上传帖子图片",
        "security": [{"BearerAuth": []}],
        "consumes": ["multipart/form-data"],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "formData", "name": "files", "type": "file", "required": true}
        ],
        "responses": {"200": {"schema": {"$ref": "#/definitions/Response"}}, "401": {}, "404": {}}
      },
      "put": {
        "tags": ["帖子"],
        "summary": "更新图片列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleImages"}}
        ],
        "responses": {"200": {"schema": {"$ref": "#/definitions/Response"}}, "401": {}, "404": {}}
      }
    },
    "/api/v1/question": {
      "get": {
        "tags": ["提问"],
        "summary": "提问列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]}}, "401": {}}
      },
      "post": {
        "tags": ["提问"],
        "summary": "创建提问",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleCreate"}}],
        "responses": {"200": {"schema": {"$ref": "#/definitions/Response"}}, "401": {}}
      }
    },
    "/api/v1/question/search": {
      "get": {
        "tags": ["提问"],
        "summary": "搜索提问",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "q", "type": "string", "required": true},
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]}}, "401": {}}
      }
    },
    "/api/v1/question/{id}": {
      "get": {
        "tags": ["提问"],
        "summary": "提问详情",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "path", "name": "id", "type": "integer", "required": true}],
        "responses": {"200": {}, "401": {}, "404": {}}
      },
      "put": {
        "tags": ["提问"],
        "summary": "更新提问",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleUpdate"}}
        ],
        "responses": {"200": {}, "401": {}, "404": {}}
      },
      "delete": {
        "tags": ["提问"],
        "summary": "删除提问",
        "security": [{"BearerAuth": []}],
        "parameters": [{"in": "path", "name": "id", "type": "integer", "required": true}],
        "responses": {"200": {}, "401": {}, "404": {}}
      }
    },
    "/api/v1/question/{id}/answers": {
      "get": {
        "tags": ["提问"],
        "summary": "该提问下的回答列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true, "description": "提问ID"},
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]}}, "401": {}}
      }
    },
    "/api/v1/question/{id}/images": {
      "post": {
        "tags": ["提问"],
        "summary": "上传提问图片",
        "security": [{"BearerAuth": []}],
        "consumes": ["multipart/form-data"],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "formData", "name": "files", "type": "file", "required": true}
        ],
        "responses": {"200": {}, "401": {}, "404": {}}
      },
      "put": {
        "tags": ["提问"],
        "summary": "更新提问图片列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "path", "name": "id", "type": "integer", "required": true},
          {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleImages"}}
        ],
        "responses": {"200": {}, "401": {}, "404": {}}
      }
    },
    "/api/v1/answer": {
      "get": {
        "tags": ["回答"],
        "summary": "回答列表",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
        "responses": {"200": {"schema": {"allOf": [{"$ref": "#/definitions/Response"}, {"properties": {"data": {"$ref": "#/definitions/ArticleListResponse"}}}]}}, "401": {}}
      },
      "post": {
        "tags": ["回答"],
        "summary": "创建回答",
        "description": "body 必须包含 parent_id（提问ID）",
        "security": [{"BearerAuth": []}],
        "parameters": [{
          "in": "body",
          "name": "body",
          "schema": {
            "allOf": [{"$ref": "#/definitions/ArticleCreate"}],
            "required": ["title", "content", "parent_id"]
          }
        }],
        "responses": {"200": {}, "400": {"description": "缺少 parent_id"}, "401": {}}
      }
    },
    "/api/v1/answer/search": {
      "get": {
        "tags": ["回答"],
        "summary": "搜索回答",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {"in": "query", "name": "q", "type": "string", "required": true},
          {"in": "query", "name": "page", "type": "integer"},
          {"in": "query", "name": "pageSize", "type": "integer"}
        ],
