{
  "swagger": "2.0",
  "info": {
    "title": "HFUT Graduation Project API",
    "description": "合肥工业大学毕业设计项目 API。需 JWT 认证、学校隔离。extType: 1=帖子 2=提问 3=回答 4=商品",
    "version": "1.0.0"
  },
  "basePath": "/",
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT，格式：Bearer {token}"
    }
  },
  "tags": [
    {"name": "系统", "description": "健康检查"},
    {"name": "用户", "description": "注册、登录、个人信息"},
    {"name": "帖子", "description": "type=1"},
    {"name": "提问", "description": "type=2"},
    {"name": "回答", "description": "type=3，创建需 parent_id"},
    {"name": "评论", "description": "评论与回复，path 传 extType：1帖子 2提问 3回答"},
    {"name": "收藏", "description": "收藏夹与收藏，path 传 extType：1帖子 2提问 3回答 4商品"},
    {"name": "点赞", "description": "点赞与取消，path 传 extType：1帖子 2提问 3回答"},
    {"name": "OSS", "description": "文件存取"},
    {"name": "管理员", "description": "需 role>=2 管理员权限"}
  ],
  "definitions": {
    "Response": {
      "type": "object",
      "properties": {
        "code": {"type": "integer", "example": 200},
        "message": {"type": "string"},
        "data": {}
      }
    },
    "ArticleCreate": {
      "type": "object",
      "required": ["title", "content"],
      "properties": {
        "title": {"type": "string"},
        "content": {"type": "string"},
        "publish_status": {"type": "integer", "description": "1私密 2公开", "default": 1},
        "parent_id": {"type": "integer", "description": "回答必传，提问ID"}
      }
    },
    "ArticleUpdate": {
      "type": "object",
      "properties": {
        "title": {"type": "string"},
        "content": {"type": "string"},
        "publish_status": {"type": "integer"}
      }
    },
    "ArticleImages": {
      "type": "object",
      "required": ["images"],
      "properties": {
        "images": {"type": "array", "items": {"type": "string"}}
      }
    },
    "CommentCreate": {
      "type": "object",
      "required": ["content"],
      "properties": {
        "content": {"type": "string"},
        "parent_id": {"type": "integer", "description": "回复时传父评论ID"},
        "reply_id": {"type": "integer", "description": "回复某条回复时传"}
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["系统"],
        "summary": "健康检查",
        "responses": {"200": {"description": "ok"}}
      }
    },
    "/api/v1/user/register": {
      "post": {
        "tags": ["用户"],
        "summary": "注册",
        "parameters": [{"in": "body", "name": "body", "schema": {"type": "object", "required": ["username", "password", "re_password"], "properties": {"username": {}, "password": {}, "re_password": {}}}}],
        "responses": {"200": {}, "400": {}}
      }
    },
    "/api/v1/user/login": {
      "post": {
        "tags": ["用户"],
        "summary": "登录",
        "parameters": [{"in": "body", "name": "body", "schema": {"type": "object", "required": ["username", "password"], "properties": {"username": {}, "password": {}}}}],
        "responses": {"200": {"description": "data 为 token"}, "400": {}, "401": {}}
      }
    },
    "/api/v1/user/info": {
      "get": {"tags": ["用户"], "summary": "当前用户信息", "security": [{"BearerAuth": []}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/user/logout": {
      "get": {"tags": ["用户"], "summary": "登出", "security": [{"BearerAuth": []}], "responses": {"200": {}}}
    },
    "/api/v1/user/update": {
      "post": {"tags": ["用户"], "summary": "更新信息", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"type": "object", "properties": {"avatar": {}, "background": {}, "bind_qq": {}, "bind_wx": {}, "bind_phone": {}}}}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/user/bind/school": {
      "post": {"tags": ["用户"], "summary": "绑定学校", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"type": "object", "required": ["school_id"], "properties": {"school_id": {"type": "integer", "description": "学校ID"}}}}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/user/avatar": {
      "post": {"tags": ["用户"], "summary": "上传头像", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "formData", "name": "file", "type": "file", "required": true}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/user/background": {
      "post": {"tags": ["用户"], "summary": "上传背景", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "formData", "name": "file", "type": "file", "required": true}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/post": {
      "get": {"tags": ["帖子"], "summary": "列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "page", "type": "integer", "default": 1}, {"in": "query", "name": "pageSize", "type": "integer", "default": 20}], "responses": {"200": {}, "401": {}}},
      "post": {"tags": ["帖子"], "summary": "创建", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleCreate"}}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/post/search": {
      "get": {"tags": ["帖子"], "summary": "搜索", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "q", "required": true, "type": "string"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/post/{id}": {
      "get": {"tags": ["帖子"], "summary": "详情", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["帖子"], "summary": "更新", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleUpdate"}}], "responses": {"200": {}, "404": {}, "401": {}}},
      "delete": {"tags": ["帖子"], "summary": "删除", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/post/{id}/images": {
      "post": {"tags": ["帖子"], "summary": "上传图片", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "formData", "name": "files", "type": "file", "required": true}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["帖子"], "summary": "更新图片列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleImages"}}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/question": {
      "get": {"tags": ["提问"], "summary": "列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}},
      "post": {"tags": ["提问"], "summary": "创建", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleCreate"}}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/question/search": {
      "get": {"tags": ["提问"], "summary": "搜索", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "q", "required": true, "type": "string"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/question/{id}": {
      "get": {"tags": ["提问"], "summary": "详情", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["提问"], "summary": "更新", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleUpdate"}}], "responses": {"200": {}, "404": {}, "401": {}}},
      "delete": {"tags": ["提问"], "summary": "删除", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/question/{id}/answers": {
      "get": {"tags": ["提问"], "summary": "回答列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/question/{id}/images": {
      "post": {"tags": ["提问"], "summary": "上传图片", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "formData", "name": "files", "type": "file", "required": true}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["提问"], "summary": "更新图片列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleImages"}}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/answer": {
      "get": {"tags": ["回答"], "summary": "列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}},
      "post": {"tags": ["回答"], "summary": "创建", "description": "必传 parent_id", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleCreate"}}], "responses": {"200": {}, "401": {}, "400": {}}}
    },
    "/api/v1/answer/search": {
      "get": {"tags": ["回答"], "summary": "搜索", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "q", "required": true, "type": "string"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/answer/{id}": {
      "get": {"tags": ["回答"], "summary": "详情", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["回答"], "summary": "更新", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleUpdate"}}], "responses": {"200": {}, "404": {}, "401": {}}},
      "delete": {"tags": ["回答"], "summary": "删除", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/answer/{id}/images": {
      "post": {"tags": ["回答"], "summary": "上传图片", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "formData", "name": "files", "type": "file", "required": true}], "responses": {"200": {}, "404": {}, "401": {}}},
      "put": {"tags": ["回答"], "summary": "更新图片列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/ArticleImages"}}], "responses": {"200": {}, "404": {}, "401": {}}}
    },
    "/api/v1/comments/{extType}/{id}": {
      "get": {"tags": ["评论"], "summary": "评论列表", "description": "extType: 1帖子 2提问 3回答", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}, "404": {}}},
      "post": {"tags": ["评论"], "summary": "发评论/回复", "description": "parent_id 回复时传", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"$ref": "#/definitions/CommentCreate"}}], "responses": {"200": {}, "401": {}, "404": {}}}
    },
    "/api/v1/comments/{extType}/{id}/{commentId}/replies": {
      "get": {"tags": ["评论"], "summary": "回复列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "path", "name": "commentId", "required": true, "type": "integer"}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}, "404": {}}}
    },
    "/api/v1/collect/folders": {
      "post": {"tags": ["收藏"], "summary": "创建收藏夹", "security": [{"BearerAuth": []}], "parameters": [{"in": "body", "name": "body", "schema": {"type": "object", "required": ["name"], "properties": {"name": {"type": "string"}}}}], "responses": {"200": {}, "401": {}}},
      "get": {"tags": ["收藏"], "summary": "收藏夹列表", "security": [{"BearerAuth": []}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/collect/folders/{id}/items": {
      "get": {"tags": ["收藏"], "summary": "收藏夹内容", "description": "ext_type=0 全部，1|2|3|4 按类型筛选", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "query", "name": "ext_type", "type": "integer", "default": 0}, {"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/collect/{extType}/{id}": {
      "post": {"tags": ["收藏"], "summary": "收藏", "description": "extType: 1帖子 2提问 3回答 4商品。body: collect_id(0=默认)", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "body", "name": "body", "schema": {"type": "object", "properties": {"collect_id": {"type": "integer"}}}}], "responses": {"200": {}, "400": {}, "401": {}, "404": {}}},
      "delete": {"tags": ["收藏"], "summary": "取消收藏", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}, {"in": "query", "name": "collect_id", "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/like/{extType}/{id}": {
      "post": {"tags": ["点赞"], "summary": "点赞", "description": "extType: 1帖子 2提问 3回答", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "400": {}, "401": {}, "404": {}}},
      "delete": {"tags": ["点赞"], "summary": "取消点赞", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "extType", "required": true, "type": "integer"}, {"in": "path", "name": "id", "required": true, "type": "integer"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/oss/{path}": {
      "get": {"tags": ["OSS"], "summary": "访问文件", "description": "公开，如 user/1/avatar.jpg", "parameters": [{"in": "path", "name": "path", "required": true, "type": "string"}], "responses": {"200": {}, "404": {}}},
      "post": {"tags": ["OSS"], "summary": "上传", "security": [{"BearerAuth": []}], "consumes": ["multipart/form-data"], "parameters": [{"in": "path", "name": "path", "required": true, "type": "string"}, {"in": "formData", "name": "file", "type": "file", "required": true}], "responses": {"200": {}, "401": {}}},
      "delete": {"tags": ["OSS"], "summary": "删除", "security": [{"BearerAuth": []}], "parameters": [{"in": "path", "name": "path", "required": true, "type": "string"}], "responses": {"200": {}, "401": {}}}
    },
    "/api/v1/admin/users": {"get": {"tags": ["管理员"], "summary": "用户列表", "security": [{"BearerAuth": []}], "parameters": [{"in": "query", "name": "page", "type": "integer"}, {"in": "query", "name": "pageSize", "type": "integer"}, {"in": "query", "name": "status", "type": "integer", "description": "0全部 1正常 2禁用"}], "responses": {"200": {}, "403": {}}}},
    "/api/v1/admin/users/{id}": {"delete": {"tags": ["管理员"], "summary": "禁用用户", "security": [{"BearerAuth": []}], "responses": {"200": {}, "403": {}}}},
    "/api/v1/admin/users/{id}/restore": {"post": {"tags": ["管理员"], "summary": "恢复用户", "security": [{"BearerAuth": []}], "responses": {"200": {}, "403": {}}}},
    "/api/v1/admin/users/{id}/role": {"put": {"tags": ["管理员"], "summary": "修改角色", "description": "body: {role: 1|2|3|4}", "security": [{"BearerAuth": []}], "responses": {"200": {}, "403": {}}}},
    "/api/v1/admin/users/{id}/status": {"put": {"tags": ["管理员"], "summary": "修改状态", "description": "body: {status: 1|2}", "security": [{"BearerAuth": []}], "responses": {"200": {}, "403": {}}}},
    "/api/v1/admin/posts": {"get": {"tags": ["管理员"], "summary": "帖子列表", "parameters": [{"in": "query", "name": "include_invalid", "type": "string", "description": "1含已删除"}]}},
    "/api/v1/admin/posts/{id}": {"delete": {"tags": ["管理员"], "summary": "禁用帖子"}},
    "/api/v1/admin/posts/{id}/restore": {"post": {"tags": ["管理员"], "summary": "恢复帖子"}},
    "/api/v1/admin/questions": {"get": {"tags": ["管理员"], "summary": "提问列表"}},
    "/api/v1/admin/questions/{id}": {"delete": {"tags": ["管理员"], "summary": "禁用提问"}},
    "/api/v1/admin/questions/{id}/restore": {"post": {"tags": ["管理员"], "summary": "恢复提问"}},
    "/api/v1/admin/answers": {"get": {"tags": ["管理员"], "summary": "回答列表"}},
    "/api/v1/admin/answers/{id}": {"delete": {"tags": ["管理员"], "summary": "禁用回答"}},
    "/api/v1/admin/answers/{id}/restore": {"post": {"tags": ["管理员"], "summary": "恢复回答"}},
    "/api/v1/admin/schools": {"get": {"tags": ["管理员"], "summary": "学校列表"}, "post": {"tags": ["管理员"], "summary": "新增学校", "description": "body: {name, login_url}"}},
    "/api/v1/admin/schools/{id}": {"delete": {"tags": ["管理员"], "summary": "下架学校"}},
    "/api/v1/admin/schools/{id}/restore": {"post": {"tags": ["管理员"], "summary": "恢复学校"}}
  }
}
