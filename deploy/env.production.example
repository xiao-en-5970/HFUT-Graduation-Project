# 服务器生产环境 .env 模板
# 填入实际值后，执行下列命令生成 DEPLOY_ENV_B64 用于 GitHub Secret：
#   cat 本文件内容 | base64 -w 0   # Linux
#   base64 -i 本文件 | tr -d '\n'  # Mac

# 应用
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_MODE=release

# PostgreSQL（1Panel 容器名，需同属 1panel-network）
DB_HOST=1Panel-postgresql-2pcq
DB_PORT=5432
DB_USER=xiao_en
DB_PASSWORD=你的数据库密码
DB_NAME=core
DB_SSLMODE=disable
DB_TIMEZONE=PRC

# Redis（1Panel 容器名）
REDIS_HOST=1Panel-redis-Fy6t
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码
REDIS_DB=0

# 日志
LOG_LEVEL=info
LOG_ENCODING=console

# JWT（生产环境务必使用强随机字符串）
JWT_SECRET=你的JWT密钥
JWT_EXPIRE_HOUR=24
