# 生产环境模板（推荐：维护 .env 后执行 make prod-env 生成 prod.env）
# 生成 DEPLOY_ENV_B64：base64 -w 0 prod.env（Linux）| base64 -i prod.env | tr -d '\n'（Mac）

# 应用
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_MODE=release

# PostgreSQL（公网 IP + 端口）
DB_HOST=47.94.197.213
DB_PORT=5432
DB_USER=xiao_en
DB_PASSWORD=你的数据库密码
DB_NAME=core
DB_SSLMODE=disable
DB_TIMEZONE=PRC

# Redis（公网 IP + 端口）
REDIS_HOST=47.94.197.213
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码
REDIS_DB=0

# 日志
LOG_LEVEL=info
LOG_ENCODING=console

# JWT（生产环境务必使用强随机字符串）
JWT_SECRET=你的JWT密钥
JWT_EXPIRE_HOUR=24

# 推荐系统（sort=recommend，方案 B：标签画像+双路召回+ε-greedy 打散）
# 留空则全部取默认值；所有参数运行时可改，重启后生效

# —— 兴趣/探索比例 ——
RECO_INTEREST_QUOTA=0.6              # 兴趣池占比（1-此值=探索池），建议 0.5~0.7

# —— 画像记忆 ——
RECO_RECENT_DAYS=3650                # 画像追溯 N 天行为，3650≈10年，相当于"永久记住用户喜好"
RECO_BEHAVIOR_TIME_DECAY_DAYS=30     # 行为时间半衰期（天）：30 意为每 30 天老行为权重减半，老兴趣渐弱但不消失
RECO_PROFILE_TTL=600                 # 用户画像 Redis 缓存秒数（越小画像越实时，但 DB 压力越高）
RECO_TOP_TAGS_LIMIT=20               # 画像保留的 top 标签数
RECO_TOP_AUTHORS_LIMIT=20            # 画像保留的 top 作者数

# —— 去重（短期，不影响画像记忆）——
RECO_SEEN_TTL_DAYS=3                 # 已曝光/已浏览过的内容 N 天内不再推；建议 3~7

# —— 召回/打散 ——
RECO_CANDIDATE_MULTIPLIER=3          # 候选池放大倍数（每路召回 pageSize×此数），翻页稳定用
RECO_FRESHNESS_DECAY_DAYS=14         # 新鲜度衰减半衰期（天）；freshness=1/(1+距今天数/此值)
RECO_INTEREST_KEEP_TOP_RATIO=0.1     # 兴趣池前 10% 按分数排序不打散（最匹配的内容优先露面）
RECO_EXPLORE_KEEP_TOP_RATIO=0.3      # 探索池前 30% 按热度排序不打散（保证热门内容在 40% 探索槽位里占大头）

# —— 行为权重（各行为在画像分数中的基础权重）——
RECO_BEHAVIOR_WEIGHT_VIEW=1          # 浏览详情
RECO_BEHAVIOR_WEIGHT_LIKE=5          # 点赞
RECO_BEHAVIOR_WEIGHT_COLLECT=8       # 收藏（最强正向信号）
RECO_BEHAVIOR_WEIGHT_COMMENT=3       # 评论
RECO_BEHAVIOR_WEIGHT_SEARCH=2        # 搜索
