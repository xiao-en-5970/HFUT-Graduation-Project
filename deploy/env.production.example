# 生产环境模板（推荐：维护 .env 后执行 make prod-env 生成 prod.env）
# 生成 DEPLOY_ENV_B64：base64 -w 0 prod.env（Linux）| base64 -i prod.env | tr -d '\n'（Mac）

# 应用
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
SERVER_MODE=release

# PostgreSQL（公网 IP + 端口）
DB_HOST=47.94.197.213
DB_PORT=5432
DB_USER=xiao_en
DB_PASSWORD=你的数据库密码
DB_NAME=core
DB_SSLMODE=disable
DB_TIMEZONE=PRC

# Redis（公网 IP + 端口）
REDIS_HOST=47.94.197.213
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码
REDIS_DB=0

# 日志
LOG_LEVEL=info
LOG_ENCODING=console

# JWT（生产环境务必使用强随机字符串）
JWT_SECRET=你的JWT密钥
JWT_EXPIRE_HOUR=24
